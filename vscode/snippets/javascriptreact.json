{
  "React Function Component": {
    "prefix": "rfc",
    "body": [
      "export default function ${1:ComponentName}() {",
      "  return (",
      "    <div>",
      "      ${2:Content}",
      "    </div>",
      "  );",
      "}"
    ],
    "description": "Create a React functional component"
  },
  
  "React Named Export Function Component": {
    "prefix": "rfce",
    "body": [
      "export function ${1:ComponentName}() {",
      "  return (",
      "    <div>",
      "      ${2:Content}",
      "    </div>",
      "  );",
      "}"
    ],
    "description": "Create a React named export functional component"
  },

  "React Function Component with Props": {
    "prefix": "rfcp",
    "body": [
      "interface ${1:ComponentName}Props {",
      "  ${2:propName}: ${3:propType};",
      "}",
      "",
      "export default function ${1:ComponentName}({ ${2:propName} }: ${1:ComponentName}Props) {",
      "  return (",
      "    <div>",
      "      ${4:Content}",
      "    </div>",
      "  );",
      "}"
    ],
    "description": "Create a React functional component with typed props"
  },

  "React useState Hook": {
    "prefix": "rus",
    "body": [
      "const [${1:state}, set${1:/capitalize}] = useState(${2:initialValue});"
    ],
    "description": "Create a useState hook"
  },

  "React useEffect Hook": {
    "prefix": "rue",
    "body": [
      "useEffect(() => {",
      "  ${1:// Effect code}",
      "}, [${2:dependencies}]);"
    ],
    "description": "Create a useEffect hook"
  },

  "React useCallback Hook": {
    "prefix": "rucb",
    "body": [
      "const ${1:callbackName} = useCallback(() => {",
      "  ${2:// Callback code}",
      "}, [${3:dependencies}]);"
    ],
    "description": "Create a useCallback hook"
  },

  "React useMemo Hook": {
    "prefix": "rum",
    "body": [
      "const ${1:memoValue} = useMemo(() => {",
      "  ${2:// Memoized value}",
      "}, [${3:dependencies}]);"
    ],
    "description": "Create a useMemo hook"
  },

  "React useContext Hook": {
    "prefix": "ruc",
    "body": [
      "const ${1:contextValue} = useContext(${2:ContextName});"
    ],
    "description": "Create a useContext hook"
  },

  "React useReducer Hook": {
    "prefix": "rur",
    "body": [
      "const [${1:state}, dispatch] = useReducer(${2:reducer}, ${3:initialState});"
    ],
    "description": "Create a useReducer hook"
  },

  "React useRef Hook": {
    "prefix": "ruref",
    "body": [
      "const ${1:ref} = useRef(${2:null});"
    ],
    "description": "Create a useRef hook"
  },

  "React Context Create": {
    "prefix": "rctx",
    "body": [
      "import { createContext, useContext } from 'react';",
      "",
      "interface ${1:ContextName}Type {",
      "  ${2:property}: ${3:type};",
      "}",
      "",
      "const ${1:ContextName}Context = createContext<${1:ContextName}Type | undefined>(undefined);",
      "",
      "export function ${1:ContextName}Provider({ children }: { children: React.ReactNode }) {",
      "  const value: ${1:ContextName}Type = {",
      "    ${2:property}: ${4:value},",
      "  };",
      "",
      "  return (",
      "    <${1:ContextName}Context.Provider value={value}>",
      "      {children}",
      "    </${1:ContextName}Context.Provider>",
      "  );",
      "}",
      "",
      "export function use${1:ContextName}() {",
      "  const context = useContext(${1:ContextName}Context);",
      "  if (!context) {",
      "    throw new Error('use${1:ContextName} must be used within ${1:ContextName}Provider');",
      "  }",
      "  return context;",
      "}"
    ],
    "description": "Create a React Context with provider and hook"
  },

  "React Custom Hook": {
    "prefix": "rhook",
    "body": [
      "export function use${1:HookName}(${2:params}) {",
      "  const [${3:state}, set${3:/capitalize}] = useState(${4:initialValue});",
      "",
      "  useEffect(() => {",
      "    ${5:// Effect code}",
      "  }, [${6:dependencies}]);",
      "",
      "  return [${3:state}, set${3:/capitalize}];",
      "}"
    ],
    "description": "Create a custom React hook"
  },

  "React Class Component": {
    "prefix": "rcc",
    "body": [
      "class ${1:ComponentName} extends React.Component {",
      "  render() {",
      "    return (",
      "      <div>",
      "        ${2:Content}",
      "      </div>",
      "    );",
      "  }",
      "}",
      "",
      "export default ${1:ComponentName};"
    ],
    "description": "Create a React class component"
  },

  "React Conditional Render": {
    "prefix": "rconditional",
    "body": [
      "{${1:condition} ? (",
      "  <div>${2:True content}</div>",
      ") : (",
      "  <div>${3:False content}</div>",
      ")}"
    ],
    "description": "Create a conditional render"
  },

  "React Map Array": {
    "prefix": "rmap",
    "body": [
      "{${1:items}.map((${2:item}) => (",
      "  <div key={${2:item}.id}>",
      "    ${3:Content}",
      "  </div>",
      "))}"
    ],
    "description": "Create a map array render"
  },

  "React Fragment": {
    "prefix": "rfrag",
    "body": [
      "<>",
      "  ${1:Content}",
      "</>"
    ],
    "description": "Create a React Fragment"
  },

  "React Import": {
    "prefix": "rimport",
    "body": [
      "import React, { ${1:Component} } from 'react';"
    ],
    "description": "Import React components"
  },

  "Import useState and useEffect": {
    "prefix": "rih",
    "body": [
      "import { useState, useEffect } from 'react';"
    ],
    "description": "Import useState and useEffect hooks"
  }
}
