{
  "React Function Component": {
    "prefix": "rfc",
    "body": [
      "export default function ${1:ComponentName}() {",
      "  return (",
      "    <div>",
      "      ${2:Content}",
      "    </div>",
      "  );",
      "}"
    ],
    "description": "Create a React functional component"
  },

  "React Named Export Function Component": {
    "prefix": "rfce",
    "body": [
      "export function ${1:ComponentName}() {",
      "  return (",
      "    <div>",
      "      ${2:Content}",
      "    </div>",
      "  );",
      "}"
    ],
    "description": "Create a React named export functional component"
  },

  "React Function Component with Props": {
    "prefix": "rfcp",
    "body": [
      "interface ${1:ComponentName}Props {",
      "  ${2:propName}: ${3:propType};",
      "}",
      "",
      "export default function ${1:ComponentName}({ ${2:propName} }: ${1:ComponentName}Props) {",
      "  return (",
      "    <div>",
      "      ${4:Content}",
      "    </div>",
      "  );",
      "}"
    ],
    "description": "Create a React functional component with typed props"
  },

  "React useState Hook": {
    "prefix": "rus",
    "body": [
      "const [${1:state}, set${1:/capitalize}] = useState<${2:type}>(${3:initialValue});"
    ],
    "description": "Create a useState hook with type"
  },

  "React useEffect Hook": {
    "prefix": "rue",
    "body": [
      "useEffect(() => {",
      "  ${1:// Effect code}",
      "}, [${2:dependencies}]);"
    ],
    "description": "Create a useEffect hook"
  },

  "React useCallback Hook": {
    "prefix": "rucb",
    "body": [
      "const ${1:callbackName} = useCallback((${2:params}: ${3:type}) => {",
      "  ${4:// Callback code}",
      "}, [${5:dependencies}]);"
    ],
    "description": "Create a useCallback hook with types"
  },

  "React useMemo Hook": {
    "prefix": "rum",
    "body": [
      "const ${1:memoValue} = useMemo<${2:type}>(() => {",
      "  ${3:// Memoized value}",
      "}, [${4:dependencies}]);"
    ],
    "description": "Create a useMemo hook with type"
  },

  "React useContext Hook": {
    "prefix": "ruc",
    "body": [
      "const ${1:contextValue} = useContext(${2:ContextName});"
    ],
    "description": "Create a useContext hook"
  },

  "React useReducer Hook": {
    "prefix": "rur",
    "body": [
      "interface ${1:State} {",
      "  ${2:property}: ${3:type};",
      "}",
      "",
      "type Action = ",
      "  | { type: '${4:ACTION_TYPE}'; payload: ${5:type} };",
      "",
      "const reducer = (state: ${1:State}, action: Action): ${1:State} => {",
      "  switch (action.type) {",
      "    case '${4:ACTION_TYPE}':",
      "      return { ...state, ${2:property}: action.payload };",
      "    default:",
      "      return state;",
      "  }",
      "};",
      "",
      "const [${6:state}, dispatch] = useReducer(reducer, ${7:initialState});"
    ],
    "description": "Create a useReducer hook with types"
  },

  "React useRef Hook": {
    "prefix": "ruref",
    "body": [
      "const ${1:ref} = useRef<${2:HTMLDivElement}>(null);"
    ],
    "description": "Create a useRef hook with type"
  },

  "React Context Create": {
    "prefix": "rctx",
    "body": [
      "import { createContext, useContext, ReactNode } from 'react';",
      "",
      "interface ${1:ContextName}Type {",
      "  ${2:property}: ${3:type};",
      "}",
      "",
      "const ${1:ContextName}Context = createContext<${1:ContextName}Type | undefined>(undefined);",
      "",
      "interface ${1:ContextName}ProviderProps {",
      "  children: ReactNode;",
      "}",
      "",
      "export function ${1:ContextName}Provider({ children }: ${1:ContextName}ProviderProps) {",
      "  const value: ${1:ContextName}Type = {",
      "    ${2:property}: ${4:value},",
      "  };",
      "",
      "  return (",
      "    <${1:ContextName}Context.Provider value={value}>",
      "      {children}",
      "    </${1:ContextName}Context.Provider>",
      "  );",
      "}",
      "",
      "export function use${1:ContextName}() {",
      "  const context = useContext(${1:ContextName}Context);",
      "  if (!context) {",
      "    throw new Error('use${1:ContextName} must be used within ${1:ContextName}Provider');",
      "  }",
      "  return context;",
      "}"
    ],
    "description": "Create a React Context with provider and hook"
  },

  "React Custom Hook": {
    "prefix": "rhook",
    "body": [
      "export function use${1:HookName}(${2:params}: ${3:type}): ${4:ReturnType} {",
      "  const [${5:state}, set${5:/capitalize}] = useState<${6:type}>(${7:initialValue});",
      "",
      "  useEffect(() => {",
      "    ${8:// Effect code}",
      "  }, [${9:dependencies}]);",
      "",
      "  return [${5:state}, set${5:/capitalize}];",
      "}"
    ],
    "description": "Create a typed custom React hook"
  },

  "React Class Component": {
    "prefix": "rcc",
    "body": [
      "interface ${1:ComponentName}Props {",
      "  ${2:propName}: ${3:propType};",
      "}",
      "",
      "interface ${1:ComponentName}State {",
      "  ${4:stateName}: ${5:stateType};",
      "}",
      "",
      "class ${1:ComponentName} extends React.Component<${1:ComponentName}Props, ${1:ComponentName}State> {",
      "  constructor(props: ${1:ComponentName}Props) {",
      "    super(props);",
      "    this.state = {",
      "      ${4:stateName}: ${6:initialValue},",
      "    };",
      "  }",
      "",
      "  render() {",
      "    return (",
      "      <div>",
      "        ${7:Content}",
      "      </div>",
      "    );",
      "  }",
      "}",
      "",
      "export default ${1:ComponentName};"
    ],
    "description": "Create a typed React class component"
  },

  "React Conditional Render": {
    "prefix": "rconditional",
    "body": [
      "{${1:condition} ? (",
      "  <div>${2:True content}</div>",
      ") : (",
      "  <div>${3:False content}</div>",
      ")}"
    ],
    "description": "Create a conditional render"
  },

  "React Map Array": {
    "prefix": "rmap",
    "body": [
      "{${1:items}.map((${2:item}: ${3:ItemType}) => (",
      "  <div key={${2:item}.id}>",
      "    ${4:Content}",
      "  </div>",
      "))}"
    ],
    "description": "Create a typed map array render"
  },

  "React Fragment": {
    "prefix": "rfrag",
    "body": [
      "<>",
      "  ${1:Content}",
      "</>"
    ],
    "description": "Create a React Fragment"
  },

  "React Import": {
    "prefix": "rimport",
    "body": [
      "import React, { ${1:Component} } from 'react';"
    ],
    "description": "Import React components"
  },

  "Import useState and useEffect": {
    "prefix": "rih",
    "body": [
      "import { useState, useEffect } from 'react';"
    ],
    "description": "Import useState and useEffect hooks"
  },

  "React forwardRef": {
    "prefix": "rforward",
    "body": [
      "interface ${1:ComponentName}Props {",
      "  ${2:propName}: ${3:propType};",
      "}",
      "",
      "export const ${1:ComponentName} = forwardRef<${4:HTMLElement}, ${1:ComponentName}Props>(",
      "  ({ ${2:propName} }, ref) => {",
      "    return (",
      "      <div ref={ref}>",
      "        ${5:Content}",
      "      </div>",
      "    );",
      "  }",
      ");"
    ],
    "description": "Create a forwardRef component"
  },

  "React memo Component": {
    "prefix": "rmemo",
    "body": [
      "interface ${1:ComponentName}Props {",
      "  ${2:propName}: ${3:propType};",
      "}",
      "",
      "function ${1:ComponentName}({ ${2:propName} }: ${1:ComponentName}Props) {",
      "  return (",
      "    <div>",
      "      ${4:Content}",
      "    </div>",
      "  );",
      "}",
      "",
      "export default memo(${1:ComponentName});"
    ],
    "description": "Create a memoized component"
  }
}
